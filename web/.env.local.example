# Dev auth for the web client (single-user mode — real auth is a later phase).
# Run `python -m scripts.seed` in the backend repo root; it prints these UUIDs.
# Copy this file to web/.env.local and paste them in.

# The seeded dev user's UUID (used as the bearer token in dev).
NEXT_PUBLIC_DEV_BEARER=

# The seeded personal + company account UUIDs (X-Account-Id header).
NEXT_PUBLIC_PERSONAL_ACCOUNT_ID=
NEXT_PUBLIC_COMPANY_ACCOUNT_ID=

# Production only: absolute backend origin (dev uses the /api rewrite instead).
# NEXT_PUBLIC_API_ORIGIN=

# Show the Billing screen in the nav (hosted-product surface; off for self-host).
# NEXT_PUBLIC_ENABLE_BILLING=1
