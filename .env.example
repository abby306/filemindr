# .env.example
DATABASE_URL=postgresql+psycopg://filemindr:localdev@localhost:5432/filemindr
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./secrets/vision-credentials.json
STORAGE_DIR=./storage

# Concurrent documents in the processing pipeline (0 = inline; tests use 0).
PIPELINE_WORKERS=3
APP_ENV=development

# Enforce plan quotas (402 on limit) — off for self-hosting; the hosted product enables it.
ENFORCE_QUOTAS=false

# Pre-load the local embedding/reranker models at startup (~400MB RAM) so the
# first query is fast. Leave false on memory-tight hosts; tests ignore it.
WARMUP_MODELS=true
